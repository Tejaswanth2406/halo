# Environment Configuration
ENVIRONMENT=production
DEBUG=False

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
COHERE_API_KEY=...
TAVILY_API_KEY=...

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=...

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=...

# Graph Database
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=...

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=...

# Search & Integration
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
GITHUB_TOKEN=...
GMAIL_API_KEY=...
JIRA_API_TOKEN=...
SLACK_BOT_TOKEN=...

# LLM Models
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_LLM_MODEL=gpt-4-turbo
DEFAULT_RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# Observability
LANGFUSE_SECRET_KEY=...
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Monitoring & Alerts
PAGERDUTY_KEY=...
SLACK_ALERT_WEBHOOK=...
DATADOG_API_KEY=...

# MLOps
MODEL_REGISTRY_PATH=/models
PROMPT_STORE_PATH=/prompts

# Feature Flags
USE_SEMANTIC_CACHE=True
USE_GRAPHRAG=True
USE_MULTIMODAL_RETRIEVAL=True
USE_LIVE_WEB_SEARCH=True
ENABLE_COST_OPTIMIZATION=True

# Rate Limiting
RATE_LIMIT_QUERIES_PER_MINUTE=100
RATE_LIMIT_TOKENS_PER_DAY=1000000

# Evaluation
RAGAS_THRESHOLD=0.7
ENABLE_OFFLINE_EVAL=True
ENABLE_ONLINE_EVAL=True

"""Gitignore for RAG system"""

# Environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Database
*.db
*.sqlite
*.sqlite3
postgres_data/
redis_data/
qdrant_data/

# Models
models/
*.pth
*.bin
*.safetensors

# Cache
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.cache/
cache/

# Logs
logs/
*.log
.logs/

# Data
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Reports
reports/
*.html

# Temporary
tmp/
temp/
.tmp/

# Docker
docker-compose.override.yml
